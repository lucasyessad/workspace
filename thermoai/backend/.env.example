# Copier ce fichier en .env et remplir les valeurs

# App
ENVIRONMENT=development   # development | production | test

# Database
DATABASE_URL=postgresql://thermopilot:thermopilot_secret@localhost:5432/thermopilot

# Redis
REDIS_URL=redis://localhost:6379/0

# Security — OBLIGATOIRE en production (générer avec: openssl rand -hex 32)
SECRET_KEY=change_me_in_production
API_KEY_HMAC_SECRET=change_me_api_key_hmac_secret

# CORS — origines autorisées séparées par des virgules
CORS_ORIGINS=["http://localhost:3000"]

# Storage (optionnel)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
S3_BUCKET_NAME=thermopilot-files
