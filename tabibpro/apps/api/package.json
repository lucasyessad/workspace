{
  "name": "@tabibpro/api",
  "version": "1.0.0",
  "description": "TabibPro — API Backend NestJS — Édition Algérie",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest-e2e.config.ts",
    "type-check": "tsc --noEmit",
    "db:migrate": "pnpm --filter @tabibpro/db-medical db:migrate && pnpm --filter @tabibpro/db-service db:migrate",
    "db:seed": "pnpm --filter @tabibpro/db-medical db:seed && pnpm --filter @tabibpro/db-service db:seed"
  },
  "dependencies": {
    "@tabibpro/shared": "workspace:*",
    "@tabibpro/db-medical": "workspace:*",
    "@tabibpro/db-service": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^8.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/bull": "^10.2.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@anthropic-ai/sdk": "^0.34.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "argon2": "^0.41.0",
    "bull": "^4.16.0",
    "ioredis": "^5.4.1",
    "nodemailer": "^6.9.16",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5",
    "puppeteer": "^23.10.1",
    "tesseract.js": "^5.1.1",
    "meilisearch": "^0.44.0",
    "minio": "^8.0.2",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "uuid": "^11.0.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "helmet": "^8.0.0",
    "compression": "^1.7.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
