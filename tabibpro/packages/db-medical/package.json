{
  "name": "@tabibpro/db-medical",
  "version": "1.0.0",
  "description": "Schéma Prisma — Base de données médicale locale",
  "main": "./generated/client/index.js",
  "types": "./generated/client/index.d.ts",
  "scripts": {
    "generate": "prisma generate --schema=./schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=./schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=./schema.prisma",
    "db:push": "prisma db push --schema=./schema.prisma",
    "db:seed": "tsx ./seed/index.ts",
    "db:reset": "prisma migrate reset --schema=./schema.prisma",
    "studio": "prisma studio --schema=./schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
