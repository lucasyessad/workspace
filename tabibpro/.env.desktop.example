# ============================================================
# TabibPro Desktop — Variables d'environnement
# Ce fichier est généré automatiquement au premier lancement
# avec des mots de passe aléatoires sécurisés.
# ============================================================

# --- Application ---
NODE_ENV=production
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
JWT_SECRET=CHANGE_ME_GENERATED_ON_FIRST_RUN
ENCRYPTION_KEY=CHANGE_ME_GENERATED_ON_FIRST_RUN

# --- Base de données médicale ---
DB_MEDICAL_NAME=tabibpro_medical
DB_MEDICAL_USER=tabibpro
DB_MEDICAL_PASSWORD=CHANGE_ME_GENERATED_ON_FIRST_RUN
DB_MEDICAL_URL=postgresql://tabibpro:CHANGE_ME@localhost:5432/tabibpro_medical

# --- Base de données service ---
DB_SERVICE_NAME=tabibpro_service
DB_SERVICE_USER=tabibpro
DB_SERVICE_PASSWORD=CHANGE_ME_GENERATED_ON_FIRST_RUN
DB_SERVICE_URL=postgresql://tabibpro:CHANGE_ME@localhost:5433/tabibpro_service

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_GENERATED_ON_FIRST_RUN

# --- Meilisearch ---
MEILISEARCH_API_KEY=CHANGE_ME_GENERATED_ON_FIRST_RUN
MEILISEARCH_HOST=http://localhost:7700

# --- MinIO ---
MINIO_ACCESS_KEY=tabibpro
MINIO_SECRET_KEY=CHANGE_ME_GENERATED_ON_FIRST_RUN
MINIO_BUCKET=tabibpro-files
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false

# --- Email (optionnel) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
