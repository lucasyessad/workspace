# ============================================================
# TabibPro — Configuration Environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ---- Application ----
NODE_ENV=production
APP_NAME="TabibPro"
APP_URL=https://app.tabibpro.dz
PATIENT_PORTAL_URL=https://patient.tabibpro.dz
APP_SECRET=your-very-secret-key-min-32-chars-here

# ---- Pays & Localisation ----
COUNTRY=DZ
DEFAULT_LOCALE=fr
SUPPORTED_LOCALES=fr,ar,ber,en
DEFAULT_TIMEZONE=Africa/Algiers
DEFAULT_CURRENCY=DZD
WEEKEND_DAYS=5,6  # Vendredi=5, Samedi=6 (semaine algérienne)

# ---- Base de données médicale (LOCAL — données sensibles) ----
DB_MEDICAL_HOST=localhost
DB_MEDICAL_PORT=5432
DB_MEDICAL_NAME=tabibpro_medical
DB_MEDICAL_USER=medgest
DB_MEDICAL_PASSWORD=change-this-strong-password
DB_MEDICAL_URL=postgresql://${DB_MEDICAL_USER}:${DB_MEDICAL_PASSWORD}@${DB_MEDICAL_HOST}:${DB_MEDICAL_PORT}/${DB_MEDICAL_NAME}

# ---- Base de données service (LOCAL ou CLOUD) ----
CLOUD_MODE=disabled  # disabled | enabled
CLOUD_PROVIDER=none  # none | algerie_telecom | ovh | hetzner | aws
DB_SERVICE_HOST=localhost
DB_SERVICE_PORT=5433
DB_SERVICE_NAME=tabibpro_service
DB_SERVICE_USER=medgest
DB_SERVICE_PASSWORD=change-this-strong-password
DB_SERVICE_URL=postgresql://${DB_SERVICE_USER}:${DB_SERVICE_PASSWORD}@${DB_SERVICE_HOST}:${DB_SERVICE_PORT}/${DB_SERVICE_NAME}

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ---- Meilisearch ----
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=change-this-meilisearch-key

# ---- MinIO (stockage fichiers) ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=tabibpro-access-key
MINIO_SECRET_KEY=change-this-minio-secret
MINIO_BUCKET_MEDICAL=tabibpro-medical
MINIO_BUCKET_DOCUMENTS=medgest-documents
MINIO_USE_SSL=false

# ---- JWT Auth ----
JWT_SECRET=your-jwt-secret-key-min-64-chars-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-min-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# ---- IA — Anthropic Claude ----
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL_FAST=claude-sonnet-4-6
AI_MODEL_DEEP=claude-opus-4-6
AI_MAX_TOKENS_PER_SESSION=50000
AI_DAILY_BUDGET_DZD=5000
AI_ENABLED=true

# ---- Email professionnel ----
EMAIL_DOMAIN=tabibpro.dz
SMTP_HOST=mail.tabibpro.dz
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=noreply@tabibpro.dz
SMTP_PASSWORD=change-this-email-password
EMAIL_FROM_NAME="TabibPro"
EMAIL_FROM=noreply@tabibpro.dz

# ---- SMS — Passerelles algériennes ----
SMS_PROVIDER=twilio  # twilio | mobilis | djezzy | ooredoo
SMS_FROM=+213XXXXXXXXX

# Twilio (test)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# ---- PubMed / NCBI ----
PUBMED_API_KEY=your-pubmed-api-key
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# ---- Backup ----
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Chaque nuit à 2h00
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/mnt/backup-usb

# ---- Sécurité ----
ENCRYPTION_KEY=32-bytes-hex-key-for-aes-256-here
MFA_ENABLED=true
SESSION_TIMEOUT_MINUTES=480  # 8 heures
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
CORS_ORIGINS=https://app.tabibpro.dz,https://patient.tabibpro.dz

# ---- Rate Limiting ----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ---- Monitoring ----
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
PROMETHEUS_ENABLED=false
LOG_LEVEL=info
