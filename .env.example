# Database
POSTGRES_DB=thermopilot
POSTGRES_USER=thermopilot
POSTGRES_PASSWORD=thermopilot_secret
DATABASE_URL=postgresql://thermopilot:thermopilot_secret@localhost:5432/thermopilot

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
ENVIRONMENT=development
DEBUG=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Storage (AWS S3 or compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
S3_BUCKET_NAME=thermopilot-files
