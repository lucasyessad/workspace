    "02-schema-supabase.sql": """
-- Extensions
create extension if not exists pgcrypto;

-- Table profiles
create table profiles (
  id uuid primary key references auth.users(id) on delete cascade,
  nom_agence text not null,
  logo text,
  telephone_whatsapp text,
  wilaya_id int not null,
  commune_id int,
  est_verifie boolean default false,
  slug_url text unique not null,
  created_at timestamptz default now()
);

-- Table listings
create table listings (
  id uuid primary key default gen_random_uuid(),
  agent_id uuid references profiles(id) on delete cascade,
  titre text not null,
  description_html text,
  prix numeric,
  surface numeric,
  type_bien text,
  type_transaction text,
  statut_publication text default 'draft',
  statut_document text,
  quartier text,
  wilaya_id int,
  commune_id int,
  etage int,
  ascenseur boolean,
  citerne_reservoir boolean,
  photos text[],
  created_at timestamptz default now()
);

-- Table wilayas
create table wilayas (
  id int primary key,
  code text,
  nom_fr text,
  nom_ar text
);

-- Table communes
create table communes (
  id bigserial primary key,
  wilaya_id int references wilayas(id),
  nom_fr text,
  nom_ar text
);

-- Index
create index idx_listings_agent on listings(agent_id);
create index idx_listings_wilaya on listings(wilaya_id);
create index idx_profiles_slug on profiles(slug_url);
""",

