{
  "SmtpServer":    "${SMTP_SERVER}",
  "Port":          25,
  "From":          "INEO.DADP.Exploitation@creditlogement.fr",
  "To":            ["DRM@creditlogement.fr"],
  "Cc":            [],
  "TemplatePath":  "${TEMPLATE_PATH}",
  "Environnement": "PROD",
  "EquipeNom":     "DSI - Exploitation",

  "Subject": "[{{STATUS_LABEL}}] [{{ENVIRONNEMENT}}] DADP - Chargement données partenaires - {{DATE}}",

  "StatusMessages": {
    "SUCCES":  "Le chargement des données partenaires DADP s'est déroulé avec succès. La table DADP_STOCK a été mise à jour.",
    "WARNING": "Le chargement DADP est terminé avec des alertes. Certains expéditeurs sont en retard ou absents.",
    "ERREUR":  "Une erreur est survenue lors du chargement DADP ou des transmissions sont manquantes. Intervention requise."
  },

  "GroupBy":      "Expediteur",
  "StatusColumn": "Statut",
  "Delimiter":    ";",
  "TitlePrefix":  "Expéditeur",
  "SortBy":       "Arrete",
  "Descending":   false,

  "BadgeColors": {
    "RECU":     { "Bg": "#2E7D32", "Text": "#FFFFFF" },
    "RETARD":   { "Bg": "#E65100", "Text": "#FFFFFF" },
    "NON_RECU": { "Bg": "#C62828", "Text": "#FFFFFF" }
  },
  "BadgeSeverity": { "NON_RECU": 3, "RETARD": 2, "RECU": 1 },

  "Columns": [
    "Arrete", "Sequence",
    "Somme_FOR",  "Evolution_FOR",
    "Somme_DEF",  "Evolution_DEF",
    "Somme_NPE",  "Evolution_NPE",
    "Somme_IMP",  "Evolution_IMP",
    "Date_chargement_INEO"
  ],
  "Headers": [
    "Arrêté",   "Séq.",
    "FOR",      "Évol. FOR",
    "DEF",      "Évol. DEF",
    "NPE",      "Évol. NPE",
    "IMP",      "Évol. IMP",
    "Chargement INEO"
  ]
}
