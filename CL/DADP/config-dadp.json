{
  "Inherits": "C:\\proclib\\CL\\config-global.json",

  "From":    "INEO.DADP.Exploitation@creditlogement.fr",
  "To":      ["DRM@creditlogement.fr"],
  "Cc":      [],

  "SubjectPrefix":   "DADP —",
  "DefaultSeverity": "Success",
  "RunbookUrl":      "",

  "RcMapping": {
    "0": "Success",
    "1": "Warning",
    "*": "Error"
  },

  "AutoSeverity": [
    { "Column": "Statut", "Operator": "Equals", "Value": "NON_RECU", "Severity": "Error"   },
    { "Column": "Statut", "Operator": "Equals", "Value": "RETARD",   "Severity": "Warning" }
  ],

  "Messages": {
    "Success":  "Le chargement des donnees partenaires DADP s'est deroule avec succes. La table DADP_STOCK a bien ete mise a jour. Vous trouverez ci-dessous la synthese par expediteur.",
    "Warning":  "Le chargement DADP est termine avec des alertes. Certains expediteurs sont en retard ou absents. Veuillez consulter la synthese ci-dessous.",
    "Error":    "Une erreur est survenue lors du chargement DADP ou des transmissions sont manquantes. Intervention requise.",
    "Critical": "Echec critique du chargement DADP. Intervention immediate requise."
  },

  "Attachments": [],

  "Data": {
    "Delimiter":   ";",
    "GroupBy":     "Expediteur",
    "TitlePrefix": "Expediteur",
    "BadgeColumn": "Statut",
    "BadgeColors": {
      "RECU":     { "Bg": "#2E7D32", "Text": "#ffffff" },
      "RETARD":   { "Bg": "#E65100", "Text": "#ffffff" },
      "NON_RECU": { "Bg": "#C62828", "Text": "#ffffff" }
    },
    "Columns": [
      "Arrete", "Sequence",
      "Somme_FOR",  "Evolution_FOR",
      "Somme_DEF",  "Evolution_DEF",
      "Somme_NPE",  "Evolution_NPE",
      "Somme_IMP",  "Evolution_IMP",
      "Date_chargement_INEO"
    ],
    "Headers": [
      "Arrete",   "Seq.",
      "FOR",      "Evol. FOR",
      "DEF",      "Evol. DEF",
      "NPE",      "Evol. NPE",
      "IMP",      "Evol. IMP",
      "Chargement INEO"
    ],
    "SortBy":     "Arrete",
    "Descending": false,
    "MaxRows":    0
  }
}
